<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Operit" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/ember_200</item>
        <item name="colorPrimaryVariant">@color/ember_700</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/clay_200</item>
        <item name="colorSecondaryVariant">@color/clay_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Declare support for drawing into the status bar / display cutout area. -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>
</resources>
